{
  "routes": [
    {
      "route": "/api/content",
      "methods": ["GET"],
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/api/figures",
      "methods": ["GET"],
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/api/likes",
      "methods": ["GET", "POST"],
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 401
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "*.{css,js,jpg,jpeg,png,ico,svg,pdf,woff,woff2,ttf,eot}"
    ]
  }
}
